{
  "name": "@svjkumar89/commitguard",
  "version": "1.1.1",
  "description": "Enterprise-grade Git policy engine — secrets detection, branch policies, SQL safety, and CI integration in one CLI",
  "license": "MIT",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=22.13.0" },
  "homepage": "https://github.com/svjkumar89/commitguard",
  "repository": { "type": "git", "url": "https://github.com/svjkumar89/commitguard.git" },
  "bugs": { "url": "https://github.com/svjkumar89/commitguard/issues" },
  "keywords": ["git", "pre-commit", "secrets-detection", "git-hooks", "security", "devops", "ci", "policy"],
  "bin": {
    "commitguard": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "picocolors": "^1.0.0",
    "execa": "^8.0.0",
    "zod": "^3.22.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@commitguard/shared": "workspace:*",
    "@commitguard/config": "workspace:*",
    "@commitguard/core": "workspace:*",
    "@commitguard/git": "workspace:*",
    "@commitguard/validators": "workspace:*",
    "@commitguard/reporters": "workspace:*",
    "@commitguard/github": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
